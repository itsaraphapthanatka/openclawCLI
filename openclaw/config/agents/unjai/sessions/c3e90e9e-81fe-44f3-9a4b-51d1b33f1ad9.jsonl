\": [\"clip_url\", \"video_url\", \"transcript\"]\n      }\n    }\n  }\n}\n```\n\n---\n\n## 🎯 วิธีใช้งาน\n\n```typescript\n// ในส่วน Journey Architect / Orchestrator\nimport { parallelSearch, searchHighlightsOnly } from './pinecone-config';\n\n// 1. ค้นหาทั้งหมด (text + video)\nconst results = await parallelSearch(userQuery, embedding, 3);\n\n// 2. ถ้ามี video ที่ตรง ให้ส่งต่อให้ 3-Filter System\nif (results.video_results.length > 0) {\n  // Journey Architect จะตัดสินใจ:\n  // - Filter 3 (Interest Match) => ส่ง video ทันที\n  // - Filter 2 (R-score > 60) => ส่ง video + quiz\n}\n\n// 3. หรือค้นหาเฉพาะ highlights โดยตรง\nconst highlights = await searchHighlightsOnly(embedding, 0.7, 3);\n```\n\n---\n\n## 📊 ตัวอย่างผลลัพธ์\n\n```json\n{\n  \"video_results\": [\n    {\n      \"source\": \"pinecone\",\n      \"id\": \"000023727e0b5dbda75ef0e43601f079\",\n      \"clip_url\": \"/static/clips/b_XdwzxHbmk_664_720.mp4\",\n      \"video_url\": \"https://www.youtube.com/watch?v=b_XdwzxHbmk\",\n      \"transcript\": \"บทเรียนเรื่องการให้อภัย...\",\n      \"score\": 0.85,\n      \"type\": \"highlight\"\n    }\n  ]\n}\n```\n\n---\n\n## ⚙️ ค่าที่ใช้\n\n| Parameter | ค่า | คำอธิบาย |\n|-----------|-----|---------|\n| **Min Score** | 0.70 | ส่ง video เฉพาะความใกล้เคียง >= 70% |\n| **Top K** | 3 | สูงสุด 3 วิดีโอต่อคำถาม |\n| **Namespace** | `highlights` | ค้นหาเฉพาะ highlight clips |\n\n---\n\nตอนนี้ Search Specialist จะค้นหาทั้งจาก **MEMORY.md** (text) และ **Pinecone** (video) พร้อมกันแล้วค่ะ! 🎉"}],"api":"openai-completions","provider":"moonshot","model":"kimi-k2.5","usage":{"input":1685,"output":1188,"cacheRead":97024,"cacheWrite":0,"totalTokens":99897,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"stop","timestamp":1773225264259}}
